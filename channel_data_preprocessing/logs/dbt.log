    create or replace table `marketing-channel-roi`.`native_raw_channel_dataset`.`raw_cleaning_members`
      
    
    

    
    OPTIONS()
    as (
      -- Cleaning layers are usually views to save storage space


WITH raw_data AS (
    -- DHYAAN DEIN: Agar tumhara source table kuch aur hai, toh yahan update kar lena
    SELECT * FROM `marketing-channel-roi`.`native_raw_channel_dataset`.`stg_members` 
)

SELECT 
    -- BigQuery Trick: Baaki saare columns waise hi le lo, bas in do ko chhod kar
    * EXCEPT(registered_via, registration_init_time),

    -- FIX 1: The "Ghost User" Patch
    -- Integer ko String banaya taaki 'Missing Info' likh sakein null aane par
    COALESCE(CAST(registered_via AS STRING), 'Missing Info') AS registered_via,

    -- FIX 2: The Date Formatter
    -- INT64 ko String banaya, aur phir %Y%m%d format padh kar DATE banaya
    PARSE_DATE('%Y%m%d', CAST(registration_init_time AS STRING)) AS registration_init_time

FROM raw_data
    );
  
